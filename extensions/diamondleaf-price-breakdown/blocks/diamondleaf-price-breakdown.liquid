{% assign pricing_ns = product.metafields.diamondleaf_pricing %}
{% assign breakdown = pricing_ns.breakdown_json.value %}
{% assign components = breakdown.components %}
{% assign source = breakdown.sourceMetafields %}

{% if pricing_ns.total_value != blank %}
  <div class="diamondleaf-price-breakdown__container">
    <details class="diamondleaf-price-breakdown__details" {% if block.settings.open_by_default %}open{% endif %} data-animate>
      <summary class="diamondleaf-price-breakdown__summary">
        <span class="diamondleaf-price-breakdown__title">
          {% if block.settings.heading != blank %}{{ block.settings.heading }}{% else %}Price Breakup{% endif %}
        </span>
        <span class="diamondleaf-price-breakdown__icon"></span>
      </summary>
      <div class="diamondleaf-price-breakdown__content">
        <div class="diamondleaf-price-breakdown__table-wrapper">
          <table class="diamondleaf-price-breakdown__table">
            <thead>
              <tr class="diamondleaf-price-breakdown__header-row">
                <th class="diamondleaf-price-breakdown__th diamondleaf-price-breakdown__th--component">Component</th>
                <th class="diamondleaf-price-breakdown__th diamondleaf-price-breakdown__th--details">Details</th>
                <th class="diamondleaf-price-breakdown__th diamondleaf-price-breakdown__th--value text-right">Value</th>
              </tr>
            </thead>
            <tbody>
              
              {% comment %} Gold Row (Highlighted) {% endcomment %}
              {% assign gold_val = pricing_ns.gold_value.value | default: components.goldValue %}
              {% if gold_val > 0 %}
                <tr class="diamondleaf-price-breakdown__tr diamondleaf-price-breakdown__tr--highlighted">
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--component">
                    <span class="diamondleaf-price-breakdown__label">GOLD</span>
                  </td>
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--details">
                    <span class="diamondleaf-price-breakdown__meta">
                      {% if source.goldPurity != blank %}{{ source.goldPurity | upcase }}{% unless source.goldPurity contains 'K' or source.goldPurity contains 'k' %}KT{% endunless %} · {% endif %}{% if components.goldWeight > 0 %}{{ components.goldWeight }} GM NET WEIGHT{% endif %}
                    </span>
                  </td>
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--value text-right">
                    <span class="diamondleaf-price-breakdown__value">{{ gold_val | times: 100 | money }}</span>
                  </td>
                </tr>
              {% endif %}

              {% comment %} Diamond Row (Highlighted) {% endcomment %}
              {% assign diamond_val = pricing_ns.diamond_value.value | default: components.diamondValue %}
              {% if diamond_val > 0 %}
                <tr class="diamondleaf-price-breakdown__tr diamondleaf-price-breakdown__tr--highlighted">
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--component">
                    <span class="diamondleaf-price-breakdown__label">
                      {% if breakdown.diamondKind == 'lab-grown' %}
                        LAB GROWN DIAMOND
                      {% elsif breakdown.diamondKind == 'natural' %}
                        NATURAL DIAMOND
                      {% else %}
                        DIAMOND
                      {% endif %}
                    </span>
                  </td>
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--details">
                    <span class="diamondleaf-price-breakdown__meta">
                      {% if components.diamondWeight > 0 %}{{ components.diamondWeight }} ct{% else %}-{% endif %}
                    </span>
                  </td>
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--value text-right">
                    <span class="diamondleaf-price-breakdown__value">{{ diamond_val | times: 100 | money }}</span>
                  </td>
                </tr>
              {% endif %}

              {% comment %} Solitaire Row (Highlighted) {% endcomment %}
              {% assign soliter_val = components.soliterValue %}
              {% if soliter_val > 0 %}
                <tr class="diamondleaf-price-breakdown__tr diamondleaf-price-breakdown__tr--highlighted">
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--component">
                    <span class="diamondleaf-price-breakdown__label">SOLITAIRE</span>
                  </td>
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--details">
                    <span class="diamondleaf-price-breakdown__meta">
                      {% if components.soliterWeight > 0 %}{{ components.soliterWeight }} ct{% else %}-{% endif %}
                    </span>
                  </td>
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--value text-right">
                    <span class="diamondleaf-price-breakdown__value">{{ soliter_val | times: 100 | money }}</span>
                  </td>
                </tr>
              {% endif %}

              {% comment %} Small Round Diamond Row {% endcomment %}
              {% assign small_round_val = components.smallRoundValue %}
              {% if small_round_val > 0 %}
                <tr class="diamondleaf-price-breakdown__tr">
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--component">
                    <span class="diamondleaf-price-breakdown__label">SMALL ROUND DIAMOND</span>
                  </td>
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--details">
                    <span class="diamondleaf-price-breakdown__meta">
                      {% if components.smallRoundWeight > 0 %}{{ components.smallRoundWeight }} ct{% else %}-{% endif %}
                    </span>
                  </td>
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--value text-right">
                    <span class="diamondleaf-price-breakdown__value">{{ small_round_val | times: 100 | money }}</span>
                  </td>
                </tr>
              {% endif %}

              {% comment %} Small Fancy Diamond Row {% endcomment %}
              {% assign small_fancy_val = components.smallFancyValue %}
              {% if small_fancy_val > 0 %}
                <tr class="diamondleaf-price-breakdown__tr">
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--component">
                    <span class="diamondleaf-price-breakdown__label">SMALL FANCY DIAMOND</span>
                  </td>
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--details">
                    <span class="diamondleaf-price-breakdown__meta">
                      {% if components.smallFancyWeight > 0 %}{{ components.smallFancyWeight }} ct{% else %}-{% endif %}
                    </span>
                  </td>
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--value text-right">
                    <span class="diamondleaf-price-breakdown__value">{{ small_fancy_val | times: 100 | money }}</span>
                  </td>
                </tr>
              {% endif %}

              {% comment %} Stone Row {% endcomment %}
              {% assign stone_val = pricing_ns.stone_value.value | default: components.stoneValue %}
              {% if stone_val > 0 %}
                <tr class="diamondleaf-price-breakdown__tr">
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--component">
                    <span class="diamondleaf-price-breakdown__label">OTHER STONES</span>
                  </td>
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--details">
                    <span class="diamondleaf-price-breakdown__meta">
                      {% if components.stoneTotalWt > 0 %}{{ components.stoneTotalWt }} ct{% else %}-{% endif %}
                    </span>
                  </td>
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--value text-right">
                    <span class="diamondleaf-price-breakdown__value">{{ stone_val | times: 100 | money }}</span>
                  </td>
                </tr>
              {% endif %}

              {% comment %} Making Charges Row {% endcomment %}
              {% assign making_val = pricing_ns.making_value.value | default: components.makingValue %}
              {% if making_val > 0 %}
                <tr class="diamondleaf-price-breakdown__tr">
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--component">
                    <span class="diamondleaf-price-breakdown__label">MAKING CHARGES</span>
                  </td>
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--details">
                    <span class="diamondleaf-price-breakdown__meta">
                      {% if source.makingCalculationType == 'percent' or source.makingCalculationType == blank %}
                        {{ components.makingPercent }}% OF 24K GOLD VALUE
                      {% else %}
                        {{ source.makingChargesPerGram }} PER GRAM
                      {% endif %}
                    </span>
                  </td>
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--value text-right">
                    <span class="diamondleaf-price-breakdown__value">{{ making_val | times: 100 | money }}</span>
                  </td>
                </tr>
              {% endif %}

              {% comment %} GST Row {% endcomment %}
              {% assign gst_val = pricing_ns.gst_value.value | default: components.gstValue %}
              {% if gst_val > 0 %}
                <tr class="diamondleaf-price-breakdown__tr">
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--component">
                    <span class="diamondleaf-price-breakdown__label">GST</span>
                  </td>
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--details">
                    <span class="diamondleaf-price-breakdown__meta">
                      {% if components.gstPercent > 0 %}{{ components.gstPercent }}%{% else %}-{% endif %}
                    </span>
                  </td>
                  <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--value text-right">
                    <span class="diamondleaf-price-breakdown__value">{{ gst_val | times: 100 | money }}</span>
                  </td>
                </tr>
              {% endif %}

              {% comment %} Total Row {% endcomment %}
              {% assign total_val = pricing_ns.total_value.value | default: components.totalPrice %}
              <tr class="diamondleaf-price-breakdown__tr diamondleaf-price-breakdown__tr--total">
                <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--component">
                  <span class="diamondleaf-price-breakdown__label">TOTAL PRICE</span>
                </td>
                <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--details">
                  <span class="diamondleaf-price-breakdown__meta">(ALL INCLUSIVE)</span>
                </td>
                <td class="diamondleaf-price-breakdown__td diamondleaf-price-breakdown__td--value text-right">
                  <span class="diamondleaf-price-breakdown__value">{{ total_val | times: 100 | money }}</span>
                </td>
              </tr>
              
            </tbody>
          </table>
        </div>
      </div>
    </details>
  </div>

  <style>
    .diamondleaf-price-breakdown__container {
      border-top: 1px solid rgba(46, 61, 54, 0.15);
      border-bottom: 1px solid rgba(46, 61, 54, 0.15);
      margin: 24px 0;
      width: 100%;
    }
    
    .diamondleaf-price-breakdown__details {
      display: block;
      width: 100%;
    }
    
    .diamondleaf-price-breakdown__summary {
      display: flex;
      justify-content: space-between;
      align-items: center;
      list-style: none;
      padding: 20px 0;
      cursor: pointer;
      user-select: none;
    }
    
    .diamondleaf-price-breakdown__summary::-webkit-details-marker {
      display: none;
    }
    
    .diamondleaf-price-breakdown__title {
      font-size: 18px;
      font-weight: 400;
      color: #2E3D36;
      letter-spacing: -0.01em;
      margin: 0;
      text-transform: none;
    }
    
    .diamondleaf-price-breakdown__icon {
      position: relative;
      display: block;
      width: 14px;
      height: 14px;
      color: #2E3D36;
      flex-shrink: 0;
    }
    
    .diamondleaf-price-breakdown__icon::before,
    .diamondleaf-price-breakdown__icon::after {
      content: "";
      position: absolute;
      background-color: currentColor;
      transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease;
    }
    
    /* Horizontal line of the plus sign */
    .diamondleaf-price-breakdown__icon::before {
      top: 6px;
      left: 0;
      width: 14px;
      height: 1.5px;
    }
    
    /* Vertical line of the plus sign */
    .diamondleaf-price-breakdown__icon::after {
      top: 0;
      left: 6px;
      width: 1.5px;
      height: 14px;
    }
    
    /* When the details element is open */
    .diamondleaf-price-breakdown__details[open] .diamondleaf-price-breakdown__icon::after {
      transform: rotate(90deg);
      opacity: 0;
    }
    
    .diamondleaf-price-breakdown__details[open] .diamondleaf-price-breakdown__icon::before {
      transform: rotate(180deg);
    }
    
    /* Smooth Details Content slide & opacity transition */
    .diamondleaf-price-breakdown__content {
      overflow: hidden;
    }
    
    .diamondleaf-price-breakdown__table-wrapper {
      width: 100%;
      overflow-x: auto;
      margin-top: 4px;
      padding-bottom: 24px;
    }
    
    .diamondleaf-price-breakdown__table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
      line-height: 1.5;
    }
    
    .diamondleaf-price-breakdown__th {
      font-size: 11px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #2E3D36;
      opacity: 0.65;
      padding: 12px;
      border-bottom: 2px solid rgba(46, 61, 54, 0.12);
      text-align: left;
    }
    
    .diamondleaf-price-breakdown__th--value {
      text-align: right;
    }
    
    .diamondleaf-price-breakdown__tr {
      border-bottom: 1px solid rgba(46, 61, 54, 0.08);
      transition: all 0.25s ease;
    }
    
    .diamondleaf-price-breakdown__tr:hover {
      background-color: rgba(46, 61, 54, 0.05);
    }
    
    .diamondleaf-price-breakdown__tr:hover .diamondleaf-price-breakdown__label,
    .diamondleaf-price-breakdown__tr:hover .diamondleaf-price-breakdown__value {
      color: #2E3D36;
      opacity: 1;
    }
    
    /* Highlighted Rows (Gold & Diamonds) */
    .diamondleaf-price-breakdown__tr--highlighted {
      background-color: rgba(46, 61, 54, 0.02);
    }
    
    .diamondleaf-price-breakdown__tr--highlighted .diamondleaf-price-breakdown__label,
    .diamondleaf-price-breakdown__tr--highlighted .diamondleaf-price-breakdown__value {
      font-weight: 500;
      opacity: 1;
    }
    
    .diamondleaf-price-breakdown__td {
      padding: 12px;
      vertical-align: middle;
      text-align: left;
    }
    
    .diamondleaf-price-breakdown__td--value {
      text-align: right;
    }
    
    .diamondleaf-price-breakdown__label {
      font-size: 13px;
      font-weight: 400;
      color: #2E3D36;
      opacity: 0.85;
      transition: all 0.2s ease;
    }
    
    .diamondleaf-price-breakdown__meta {
      font-size: 12px;
      color: #2E3D36;
      opacity: 0.65;
      font-weight: 400;
    }
    
    .diamondleaf-price-breakdown__value {
      font-size: 13px;
      font-weight: 400;
      color: #2E3D36;
      opacity: 0.9;
      transition: all 0.2s ease;
    }
    
    /* Total Row styles */
    .diamondleaf-price-breakdown__tr--total {
      border-top: 1px solid #2E3D36;
      border-bottom: none;
      background-color: rgba(46, 61, 54, 0.06);
    }
    
    .diamondleaf-price-breakdown__tr--total:hover {
      background-color: rgba(46, 61, 54, 0.08);
    }
    
    .diamondleaf-price-breakdown__tr--total:hover .diamondleaf-price-breakdown__label,
    .diamondleaf-price-breakdown__tr--total:hover .diamondleaf-price-breakdown__value {
      color: #2E3D36;
      opacity: 1;
    }
    
    .diamondleaf-price-breakdown__tr--total .diamondleaf-price-breakdown__label {
      font-size: 14px;
      font-weight: 600;
      color: #2E3D36;
      opacity: 1;
    }
    
    .diamondleaf-price-breakdown__tr--total .diamondleaf-price-breakdown__meta {
      font-size: 11px;
      font-weight: 500;
      color: #2E3D36;
      opacity: 0.85;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    
    .diamondleaf-price-breakdown__tr--total .diamondleaf-price-breakdown__value {
      font-size: 15px;
      font-weight: 600;
      color: #2E3D36;
      opacity: 1;
    }
  </style>

  <script>
    class DiamondleafAccordion {
      constructor(el) {
        this.el = el;
        this.summary = el.querySelector('.diamondleaf-price-breakdown__summary');
        this.content = el.querySelector('.diamondleaf-price-breakdown__content');
        this.isClosing = false;
        this.isExpanding = false;
        this.animation = null;
        
        this.summary.addEventListener('click', (e) => this.onClick(e));
      }
      
      onClick(e) {
        e.preventDefault();
        this.el.style.overflow = 'hidden';
        if (this.isClosing || !this.el.open) {
          this.open();
        } else if (this.isExpanding || this.el.open) {
          this.shrink();
        }
      }
      
      shrink() {
        this.isClosing = true;
        const startHeight = `${this.content.offsetHeight}px`;
        const endHeight = '0px';
        
        if (this.animation) {
          this.animation.cancel();
        }
        
        this.animation = this.content.animate({
          height: [startHeight, endHeight],
          opacity: [1, 0]
        }, {
          duration: 300,
          easing: 'cubic-bezier(0.4, 0, 0.2, 1)'
        });
        
        this.animation.onfinish = () => this.onAnimationFinish(false);
      }
      
      open() {
        this.el.open = true;
        window.requestAnimationFrame(() => this.expand());
      }
      
      expand() {
        this.isExpanding = true;
        const startHeight = '0px';
        const endHeight = `${this.content.offsetHeight}px`;
        
        if (this.animation) {
          this.animation.cancel();
        }
        
        this.animation = this.content.animate({
          height: [startHeight, endHeight],
          opacity: [0, 1]
        }, {
          duration: 350,
          easing: 'cubic-bezier(0.4, 0, 0.2, 1)'
        });
        
        this.animation.onfinish = () => this.onAnimationFinish(true);
      }
      
      onAnimationFinish(open) {
        this.el.open = open;
        this.animation = null;
        this.isClosing = false;
        this.isExpanding = false;
        this.el.style.overflow = '';
      }
    }

    // Initialize once DOM is fully loaded or updated
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.diamondleaf-price-breakdown__details[data-animate]').forEach((el) => {
        new DiamondleafAccordion(el);
      });
    });

    // Support theme editor dynamic loads
    if (window.Shopify && window.Shopify.designMode) {
      document.addEventListener('shopify:section:load', () => {
        document.querySelectorAll('.diamondleaf-price-breakdown__details[data-animate]').forEach((el) => {
          new DiamondleafAccordion(el);
        });
      });
    }
  </script>
{% endif %}

{% schema %}
{
  "name": "Diamondleaf Price",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Price Breakup"
    },
    {
      "type": "checkbox",
      "id": "open_by_default",
      "label": "Open details by default",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Diamondleaf Price Breakdown"
    }
  ]
}
{% endschema %}
