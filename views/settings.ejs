<%- include("partials/header") %>
<section class="hero compact">
  <div>
    <p class="eyebrow">Configuration</p>
    <h1>Pricing settings</h1>
    <p class="lead">
      Edit the pricing rules, gold rates, lab-grown slabs, and metafield key mapping here.
    </p>
  </div>
  <a class="button" href="/">Back to dashboard</a>
</section>

<section class="card card-feature">
  <% if (error) { %>
    <div class="notice error"><%= error %></div>
  <% } %>

  <form method="post" action="/settings" class="stack">
    <label for="configJson">Configuration JSON</label>
    <textarea id="configJson" name="configJson" rows="32"><%= configJson %></textarea>
    <p class="hint">
      Important: set <code>defaultNaturalDiamondFlatPricePerCt</code> or create the
      <code>natural_diamond_price_ct</code> product metafield for natural diamonds.
    </p>
    <button class="button button-primary" type="submit">Save settings</button>
  </form>
</section>
<%- include("partials/footer") %>
